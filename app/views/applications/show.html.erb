<div class="container mx-auto max-w-2xl px-4 py-8">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-4">Application Status</h1>
  </div>

  <div class="bg-white shadow-lg rounded-lg p-8">
    <div class="mb-6">
      <h2 class="text-xl font-semibold text-gray-800 mb-2">Your Application</h2>
      <p class="text-gray-600 mb-4"><strong>Email:</strong> <%= @application.email %></p>
      
      <div class="bg-gray-50 rounded-lg p-4 mb-6">
        <p class="text-gray-700"><%= simple_format(@application.application_text) %></p>
      </div>
    </div>

    <div class="mb-6">
      <h3 class="text-lg font-semibold text-gray-800 mb-4">Current Status</h3>
      
      <% case @application.status %>
      <% when 'unverified' %>
        <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4">
          <div class="flex items-center">
            <div class="w-3 h-3 bg-yellow-400 rounded-full mr-3"></div>
            <span class="text-yellow-800 font-semibold">Email Verification Required</span>
          </div>
          <p class="text-yellow-700 mt-2">Please check your email and click the verification link to continue.</p>
        </div>
      
      <% when 'pending' %>
        <div class="bg-blue-50 border border-blue-200 rounded-md p-4">
          <div class="flex items-center">
            <div class="w-3 h-3 bg-blue-400 rounded-full mr-3"></div>
            <span class="text-blue-800 font-semibold">Under Review</span>
          </div>
          <p class="text-blue-700 mt-2">Your application is being reviewed by our team. We'll notify you once a decision is made.</p>
        </div>
      
      <% when 'approved' %>
        <div class="bg-green-50 border border-green-200 rounded-md p-4">
          <div class="flex items-center">
            <div class="w-3 h-3 bg-green-400 rounded-full mr-3"></div>
            <span class="text-green-800 font-semibold">Approved</span>
          </div>
          <p class="text-green-700 mt-2">Great news! Your application has been approved. You're now in our matching pool!</p>
        </div>
      
      <% when 'matched' %>
        <div class="bg-purple-50 border border-purple-200 rounded-md p-4 mb-4">
          <div class="flex items-center">
            <div class="w-3 h-3 bg-purple-400 rounded-full mr-3"></div>
            <span class="text-purple-800 font-semibold">Matched!</span>
          </div>
          <p class="text-purple-700 mt-2">Congratulations! You've been matched with a pen pal. Check your email for their contact information.</p>
        </div>
        
        <% if @application.match %>
          <div class="bg-gray-50 rounded-lg p-4">
            <h4 class="font-semibold text-gray-800 mb-2">Match Details</h4>
            <p class="text-gray-600 text-sm">
              Matched on: <%= @application.match.matched_at.strftime("%B %d, %Y") %>
            </p>
          </div>
        <% end %>
      
      <% when 'rejected' %>
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <div class="flex items-center">
            <div class="w-3 h-3 bg-red-400 rounded-full mr-3"></div>
            <span class="text-red-800 font-semibold">Not Approved</span>
          </div>
          <p class="text-red-700 mt-2">Unfortunately, your application wasn't approved at this time. You can submit a new application if you'd like to try again.</p>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-8">
      <p class="text-sm text-gray-500">
        Bookmark this page to check your status anytime.<br>
        Submitted on <%= @application.created_at.strftime("%B %d, %Y at %I:%M %p") %>
      </p>
    </div>
  </div>
</div>
