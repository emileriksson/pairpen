<div class="container mx-auto max-w-2xl px-4 py-8">
  <div class="text-center mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Find Your Pen Pal</h1>
    <p class="text-xl text-gray-600 mb-8">
      Connect with someone special through the art of written correspondence. 
      Share stories, experiences, and build meaningful friendships across the world.
    </p>
  </div>

  <%= form_with model: @application, local: true, class: "bg-white shadow-lg rounded-lg p-8" do |form| %>
    <% if @application.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4 mb-6">
        <h3 class="text-red-800 font-semibold mb-2">Please fix the following errors:</h3>
        <ul class="text-red-700 text-sm list-disc list-inside">
          <% @application.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-6">
      <%= form.label :email, "Your Email Address", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.email_field :email, 
          class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          placeholder: "your.email@example.com",
          required: true %>
      <p class="text-sm text-gray-500 mt-1">We'll use this to verify your application and match notifications.</p>
    </div>

    <div class="mb-6">
      <%= form.label :application_text, "Tell us about yourself", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :application_text, 
          rows: 8,
          class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500",
          placeholder: "Share a bit about yourself, your interests, what you're looking for in a pen pal, and what makes you excited about writing letters. Minimum 50 characters, maximum 1000.",
          required: true %>
      <p class="text-sm text-gray-500 mt-1">
        Minimum 50 characters, maximum 1000. Be authentic and let your personality shine through!
      </p>
    </div>

    <div class="mb-6">
      <div class="bg-blue-50 border border-blue-200 rounded-md p-4">
        <h3 class="text-blue-800 font-semibold mb-2">What happens next?</h3>
        <ol class="text-blue-700 text-sm space-y-1 list-decimal list-inside">
          <li>You'll receive an email to verify your application</li>
          <li>Our team will review your application</li>
          <li>If approved, we'll match you with a compatible pen pal</li>
          <li>You'll both receive each other's contact information</li>
        </ol>
      </div>
    </div>

    <div class="text-center">
      <%= form.submit "Submit Application", 
          class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg shadow-md transition duration-200 ease-in-out transform hover:scale-105" %>
    </div>
  <% end %>
</div>
